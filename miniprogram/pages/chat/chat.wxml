<view class="chat-page">
  <view class="stage-bar">
    <text class="stage-item {{item.done ? 'done' : ''}} {{item.current ? 'current' : ''}}" 
          wx:for="{{stages}}" wx:key="name">{{item.name}}</text>
  </view>

  <scroll-view class="chat-messages" scroll-y="true" scroll-into-view="msg-bottom">
    <view class="msg {{item.type === 'ai' ? 'msg-ai' : 'msg-user'}}" 
          wx:for="{{messages}}" wx:key="index" id="msg-{{index}}">
      <view class="msg-avatar">
        <image wx:if="{{item.type === 'ai'}}" src="/images/avatar-ai.png" class="msg-avatar-img" mode="aspectFit"/>
        <image wx:else src="/images/avatar-user.png" class="msg-avatar-img" mode="aspectFit"/>
      </view>
      <view class="msg-bubble">
        <text class="msg-text">{{item.text}}</text>
        <view class="msg-voice" wx:if="{{item.type === 'ai'}}">
          <view class="voice-waves">
            <view class="wave"></view>
            <view class="wave"></view>
            <view class="wave"></view>
            <view class="wave"></view>
          </view>
          <text class="voice-text">点击播放语音</text>
        </view>
        <view class="msg-voice" wx:if="{{item.type === 'user'}}">
          <text class="voice-text">0:32</text>
        </view>
      </view>
    </view>
    <view id="msg-bottom"></view>
  </scroll-view>

  <view class="chat-input">
    <view class="mic-wrap">
      <button class="mic-btn {{recording ? 'recording' : ''}}" bindtap="toggleMic">
        <view class="mic-icon">
          <image wx:if="{{recording}}" src="/images/icon-mic-recording.png" class="mic-img" mode="aspectFit"/>
          <image wx:else src="/images/icon-mic-idle.png" class="mic-img" mode="aspectFit"/>
        </view>
      </button>
      <text class="mic-hint">{{recording ? '松开结束录音' : '按住说话，松开发送'}}</text>
    </view>
  </view>
</view>
