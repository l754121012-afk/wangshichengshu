.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg);
}

.stage-bar {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  padding: 16rpx;
  font-size: 24rpx;
  color: var(--muted);
  background: var(--bg2);
  border-bottom: 2rpx solid var(--rule);
}

.stage-item.done {
  color: var(--accent2);
  font-weight: 600;
}

.stage-item.current {
  color: var(--accent);
  font-weight: 700;
}

.chat-messages {
  flex: 1;
  padding: 32rpx;
  overflow-y: auto;
}

.msg {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.msg-ai { flex-direction: row; }
.msg-user { flex-direction: row-reverse; }

.msg-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.msg-ai .msg-avatar { background: var(--accent); }
.msg-user .msg-avatar { background: var(--accent2); }

.msg-bubble {
  max-width: 70%;
  padding: 24rpx 32rpx;
  border-radius: 32rpx;
  font-size: 30rpx;
  line-height: 1.7;
}

.msg-ai .msg-bubble {
  background: var(--white);
  border: 2rpx solid var(--rule);
  border-top-left-radius: 8rpx;
}

.msg-user .msg-bubble {
  background: var(--accent);
  color: white;
  border-top-right-radius: 8rpx;
}

.msg-voice {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: var(--muted);
}

.voice-waves {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.wave {
  width: 6rpx;
  height: 20rpx;
  background: var(--muted);
  border-radius: 4rpx;
  animation: wave 1s ease-in-out infinite;
}

.wave:nth-child(2) { animation-delay: 0.1s; height: 28rpx; }
.wave:nth-child(3) { animation-delay: 0.2s; height: 16rpx; }
.wave:nth-child(4) { animation-delay: 0.3s; height: 24rpx; }

@keyframes wave {
  0%, 100% { transform: scaleY(0.5); }
  50% { transform: scaleY(1.2); }
}

.chat-input {
  padding: 24rpx 40rpx 48rpx;
  background: var(--white);
  border-top: 2rpx solid var(--rule);
}

.mic-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.mic-btn {
  width: 112rpx;
  height: 112rpx;
  background: var(--accent);
  border: none;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(198,93,33,0.25);
  padding: 0;
  margin: 0;
}

.mic-btn.recording {
  background: var(--red);
  animation: pulse 1s ease infinite;
}

@keyframes pulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(192,57,43,0.3); }
  50% { box-shadow: 0 0 0 24rpx rgba(192,57,43,0); }
}

.mic-icon {
  font-size: 48rpx;
  color: white;
}

.mic-hint {
  font-size: 22rpx;
  color: var(--muted);
  margin-top: 12rpx;
}
