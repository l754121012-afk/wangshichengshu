<view class="home-page">
  <view class="home-hero">
    <view class="logo">[书]</view>
    <view class="home-title">往事成书</view>
    <view class="home-subtitle">{{parentName}}的回忆录</view>
  </view>

  <view class="card">
    <view class="progress-header">
      <text class="progress-title">写作进度</text>
      <text class="progress-num">第{{currentChapter}}章/共{{totalChapters}}章</text>
    </view>
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{progress}}%"></view>
    </view>
    <view class="progress-stages">
      <view class="stage {{item.done ? 'done' : ''}} {{item.current ? 'current' : ''}}" 
            wx:for="{{stages}}" wx:key="name">{{item.name}} {{item.done ? '✓' : item.current ? '●' : ''}}</view>
    </view>
  </view>

  <view class="card greeting-card">
    <view class="ai-badge">[AI] AI采访者</view>
    <text class="greeting-text">{{parentName}}早上好！今天想聊聊您年轻时工作的事情吗？上次您说到在工厂的第一天，后来怎么样了？</text>
  </view>

  <button class="big-btn" bindtap="startChat">
    <text class="btn-icon">[麦]</text>
    <text>开始讲述</text>
  </button>

  <view class="quick-actions">
    <view class="quick-action" bindtap="goMemoir">
      <view class="quick-icon book">[阅]</view>
      <text>查看回忆录</text>
    </view>
    <view class="quick-action">
      <view class="quick-icon camera">[照]</view>
      <text>上传照片</text>
    </view>
    <view class="quick-action">
      <view class="quick-icon family">[家]</view>
      <text>邀请家人</text>
    </view>
  </view>
</view>
