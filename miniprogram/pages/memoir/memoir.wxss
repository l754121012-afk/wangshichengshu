.memoir-page {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 120rpx;
}

.memoir-header {
  background: linear-gradient(170deg, var(--bg3) 0%, var(--bg) 100%);
  padding: 32rpx 48rpx 48rpx;
  text-align: center;
}

.memoir-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.memoir-subtitle {
  font-size: 26rpx;
  color: var(--muted);
  font-style: italic;
}

.chapter-list {
  padding: 32rpx;
}

.chapter-item {
  background: var(--white);
  border: 2rpx solid var(--rule);
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.chapter-item.locked {
  opacity: 0.4;
}

.chapter-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.chapter-num {
  font-size: 22rpx;
  color: var(--accent);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.chapter-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.chapter-preview {
  font-size: 24rpx;
  color: var(--muted);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.chapter-meta {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: var(--muted);
}
