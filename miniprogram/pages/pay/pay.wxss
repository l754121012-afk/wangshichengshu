.pay-page {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 120rpx;
}

.pay-header {
  background: linear-gradient(170deg, var(--accent) 0%, #A04A1A 100%);
  padding: 48rpx;
  text-align: center;
  color: white;
}

.pay-icon {
  width: 112rpx;
  height: 112rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 50%;
  margin: 24rpx auto;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pay-icon-img {
  width: 64rpx;
  height: 64rpx;
}

.pay-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.pay-subtitle {
  font-size: 26rpx;
  opacity: 0.85;
  line-height: 1.6;
}

.pay-plans {
  padding: 32rpx;
}

.plan-card {
  background: var(--white);
  border: 4rpx solid var(--rule);
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  position: relative;
}

.plan-card.recommended {
  border-color: var(--accent);
}

.plan-card.dashed {
  border-style: dashed;
}

.plan-badge {
  position: absolute;
  top: -20rpx;
  right: 32rpx;
  background: var(--accent);
  color: white;
  font-size: 20rpx;
  font-weight: 700;
  padding: 6rpx 20rpx;
  border-radius: 40rpx;
}

.plan-name {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.plan-desc {
  font-size: 24rpx;
  color: var(--muted);
  margin-bottom: 20rpx;
}

.plan-price {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  margin-bottom: 24rpx;
}

.price-symbol {
  font-size: 28rpx;
  color: var(--accent);
}

.price-amount {
  font-size: 56rpx;
  font-weight: 800;
  color: var(--accent);
}

.price-unit {
  font-size: 26rpx;
  color: var(--muted);
}

.price-original {
  font-size: 22rpx;
  color: var(--muted);
  text-decoration: line-through;
  margin-left: 16rpx;
}

.plan-features {
  margin-top: 24rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 6rpx 0;
  font-size: 26rpx;
  color: var(--ink);
}

.feature-check {
  color: var(--accent2);
  font-weight: 700;
}
