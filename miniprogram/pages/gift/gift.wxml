<view class="gift-page">
  <view class="gift-icon">
    <image src="/images/gift-box.png" class="gift-icon-img" mode="aspectFit"/>
  </view>
  <view class="gift-title">送给爸妈一份特别的礼物</view>
  <view class="gift-subtitle">用AI帮父母写一本回忆录，留下他们一生的故事</view>

  <view class="form-group">
    <text class="form-label">父母的名字</text>
    <input class="form-input" value="{{parentName}}" bindinput="onNameInput" placeholder="请输入名字"/>
  </view>

  <view class="form-group">
    <text class="form-label">年龄</text>
    <input class="form-input" value="{{parentAge}}" bindinput="onAgeInput" placeholder="请输入年龄" type="number"/>
  </view>

  <view class="form-group">
    <text class="form-label">您是ta的</text>
    <view class="relation-select">
      <view class="relation-btn {{selectedRelation === item ? 'selected' : ''}}" 
            wx:for="{{relations}}" 
            wx:key="*this"
            data-relation="{{item}}"
            bindtap="selectRelation">{{item}}</view>
    </view>
  </view>

  <button class="gift-btn" bindtap="createMemoir">创建回忆录 · 29.9元</button>
  <view class="gift-note">支付后自动生成邀请链接，发给爸妈即可开始；不满意可申请全额退款</view>
</view>
