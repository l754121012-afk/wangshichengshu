page {
  --bg: #FDF8F0;
  --bg2: #F3EBE0;
  --bg3: #E8D5C4;
  --ink: #2C1810;
  --muted: #8B7355;
  --rule: #D4C5B0;
  --accent: #C65D21;
  --accent2: #2E7D5B;
  --gold: #B8860B;
  --white: #FFFFFF;
  --red: #C0392B;
  background: var(--bg);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  color: var(--ink);
  line-height: 1.6;
}

.container {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 120rpx;
}

/* Common */
.big-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin: 40rpx;
  padding: 36rpx;
  background: var(--accent);
  color: white;
  border: none;
  border-radius: 32rpx;
  font-size: 36rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 48rpx rgba(198,93,33,0.25);
}

.card {
  background: var(--white);
  border-radius: 32rpx;
  padding: 32rpx;
  margin: 0 40rpx 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(44,24,16,0.06);
}

.card-title {
  font-weight: 700;
  font-size: 30rpx;
  margin-bottom: 16rpx;
  color: var(--accent);
}

/* Progress bar */
.progress-bar {
  height: 16rpx;
  background: var(--bg2);
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--accent), var(--gold));
  border-radius: 8rpx;
}

/* Status tags */
.tag {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 40rpx;
  font-size: 22rpx;
  font-weight: 600;
}
.tag-complete { background: rgba(46,125,91,0.1); color: var(--accent2); }
.tag-writing { background: rgba(198,93,33,0.1); color: var(--accent); }
.tag-locked { background: var(--bg2); color: var(--muted); }

/* Safe area */
.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
